{
	"schemaVersion": 1,
	"id": "nojumpdelay",
	"version": "${version}",
	"name": "NoJumpDelay",
	"description": "Removes the delay when jumping, allowing for spacebar to be held instead of spammed, and improving the feel of movement/parkour",
	"authors": [
		"Flowng",
		"Kadalyst",
		"xlzv / czxd"
	],
	"contact": {
		"homepage": "https://kadthehunter.github.io",
		"sources": "https://github.com/KadTheHunter/NoJumpDelay"
	},
	"license": "MIT",
	"icon": "assets/nojumpdelay/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"com.kadalyst.nojumpdelay.NoJumpDelay"
		],
		"modmenu": [
			"com.kadalyst.nojumpdelay.config.ModMenuPlugin"
		]
	},
	"depends": {
		"fabricloader": ">=0.17.3",
		"minecraft": ">=1.21.9",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"cloth-config": ">=20.0.148",
		"modmenu": ">=16.0.0-rc.1"
	},
	"mixins": [
		"nojumpdelay-mixins.json"
	]
}